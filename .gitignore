# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# cloudflare wrangler の一時・ビルド成果物（worker/.wrangler など）
.wrangler/

# production
/build

# uploaded media (local filesystem storage; production uses R2/S3/Drive)
/public/uploads

# 永続化データ（file アダプタ）＆ クライアント別インスタンス（データ・秘密情報）
/.data
/clients

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
