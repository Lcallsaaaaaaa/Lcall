# =============================================================================
# LCall 環境変数テンプレート（納品時設定の早見表）
#   [必須]=本番で必要 / [任意]=その機能を使う時だけ / [運営]=運営コンソールのみ
#   クライアント1社＝1インスタンス（モデルB）。運営コンソールは別インスタンス（LCALL_CONTROL_PLANE=true）。
#   実値はここに書かない（コミットされる）。各ホストの環境変数 or .env.local に設定。
#   ※ provision（npm run provision -- <slug> ...）が下記の大半を自動生成します。
# =============================================================================

# ===== 永続化（本番はPostgres推奨） =====
# 本番・推奨: PostgreSQL（Neon等）。これを設定すると postgres アダプタを使用。
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require   # [必須(本番)]
PG_POOL_MAX=3                                                        # [任意] 共有Postgresは低め推奨
# 代替: ファイル永続化（単一インスタンス・最安）。DATABASE_URL を使うなら不要。
# LCALL_DATA_ADAPTER=file
# LCALL_DATA_FILE=./clients/<slug>/data.json
# LCALL_SEED=empty            # 新規クライアントはデモ無しで開始

# ===== 認証・基盤 =====
LCALL_SESSION_SECRET=         # [必須] セッション署名鍵。クライアント毎にユニークな乱数
LCALL_WORKER_KEY=             # [必須] cron/計測の共有鍵（/api/scenarios/run 等）
LCALL_ADMIN_EMAIL=            # [必須] オーナーのログインメール
LCALL_ADMIN_PASSWORD_HASH=    # [必須] scrypt ハッシュ（npm run hash-password -- 'パスワード'）
LCALL_ALLOW_DEV_LOGIN=false   # [必須] 本番は false（true=パスワード無しログイン＝デモのみ）
# LCALL_ADMIN_NAME=           # [任意] 管理者の表示名

# ===== 公開URL（共有リンク/Webhook URL/登録URL/決済戻りの基底） =====
LCALL_PUBLIC_BASE_URL=https://YOUR-APP.example.com   # [必須] 公開URL。プロキシ背後の内部ホスト混入を防ぐ

# ===== 運営コンソール連携 =====
LCALL_OPERATOR_KEY=           # [必須] 運営コンソールからの監視/遠隔操作の共有鍵。クライアント毎にユニーク
# LCALL_CONTROL_PLANE=true    # [運営] 運営コンソールのインスタンスでのみ true（クライアントは未設定）

# ===== クリック計測（Cloudflare Worker） =====
TRACKING_BASE_URL=            # [任意] このクライアント用 Worker のURL（dev は http://localhost:8787）

# ===== AI自動応答（Anthropic） =====
ANTHROPIC_API_KEY=            # [任意] 未設定ならAIは無反応（安全）。アカウント別キーはLINEアカウント編集で設定可

# ===== 決済（Stripe） =====
STRIPE_SECRET_KEY=            # [任意] sk_live_... / sk_test_...（未設定はモック請求）。pk_ は不可
STRIPE_WEBHOOK_SECRET=        # [任意] whsec_...（ダッシュボード or `stripe listen`）

# ===== 画像保存（Cloudflare R2 / S3互換） =====
# 未設定ならローカル public/uploads（LINEのカルーセル画像はHTTPS必須＝本番はR2推奨）
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_BASE_URL=https://your-bucket-public-domain

# ===== Google OAuth（メール+パスワードに加えて併用する場合のみ） =====
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://YOUR-APP.example.com/api/auth/google/callback
# LCALL_ALLOWED_EMAILS=       # 許可メール（カンマ/空白区切り）。OAuth利用時は必須（空だと全拒否）

# ===== デモ環境のみ（任意） =====
# LCALL_DEMO=true             # 「これはデモ環境です」バナー表示
# UPSTASH_REDIS_REST_URL=     # サーバーレスのデモ用（Vercel等）。Render+Neon本番では不要
# UPSTASH_REDIS_REST_TOKEN=
